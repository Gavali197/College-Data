@model Webapplication1Mvc.models.ProductGstdetail

@{
    ViewData["Title"] = "Create";
}

<h1>Create GST</h1>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" method="post">

            <div class="form-group mb-3">
                <label asp-for="ProductId"></label>
                <select asp-for="ProductId"
                        class="form-control"
                        asp-items="ViewBag.ProductId"
                        onchange="this.form.submit()">
                    <option value="">-- Select Product --</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Sgst"></label>
                <input asp-for="Sgst" class="form-control" readonly />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Cgst"></label>
                <input asp-for="Cgst" class="form-control" readonly />
            </div>

            <div class="form-group mb-3">
                <label asp-for="TotalGst"></label>
                <input asp-for="TotalGst" class="form-control" readonly />
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
        </form>
    </div>
</div>